    "settings.agents.resumeFooter" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On next launch, auto-run the latest saved resume command to land back in the most recent session. Off by default. Turning a row off also drops any saved session id."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "次回起動時に、保存済みの最新 resume コマンドを自動実行して直近のセッションへ戻ります。既定ではオフです。行をオフにすると保存済みのセッション ID も削除されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下次启动时自动执行最近保存的 resume 命令，回到最近一次会话。默认关闭。关闭某一行同时会清除已保存的会话 id。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下次啟動時自動執行最近儲存的 resume 命令，回到最近一次工作階段。預設關閉。關閉某一列也會清除已儲存的工作階段 id。"
          }
        }
      }
    },
    "settings.agents.resumeTitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
